VERSION 1.0 CLASS
BEGIN
  MultiUse = -1  'True
END
Attribute VB_Name = "clsWaitCursor"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = False
Option Explicit

' *****************************************************
' Klasse JWaitCursor
' *****************************************************

' Diese Klasse implementiert einen Wait Cursor, der automatisch
' wieder zum normalen Cursor wird, sobald der G³ltigkeitsbereich
' des Objekts verlassen wird

' Anwendung:
' dim wait as new JWaitCursor
' wait.show

' =====================================================
' Public
' =====================================================

' Der Cursor õndert sich auf xlWait
Public Sub Show(Optional ByVal Kind As XlMousePointer = XlMousePointer.xlWait)
    If Not TESTMODE Then Application.Cursor = xlWait
End Sub

' Der Cursor õndert sich zur³ck auf den normalen Zeiger
Public Sub Hide()
    If Not TESTMODE Then Application.Cursor = xlDefault
End Sub

' =====================================================
' Private
' =====================================================

' Der Cursor õndert sich automatisch auf den normalen Zeiger, wenn die Instanz
' ihren G³ltigkeitsbereich verlõsst
Private Sub Class_Terminate()
    Hide
End Sub

